# Local development only.
# Copy this file to api/.env and fill in real values for local Docker dev.
# In production (Coolify), these variables are set in the Coolify UI's
# Environment Variables panel for each team's app — there is no .env file
# on the production server.

SECRET_KEY=<change-this-to-a-random-secret>
DB_USER=root
DB_HOST=db
DB_PORT=3306
DB_NAME=ngo_db
MYSQL_ROOT_PASSWORD=<change-this-to-a-strong-password>

